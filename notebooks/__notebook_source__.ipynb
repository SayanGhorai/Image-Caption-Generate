from transformers import AutoTokenizer, AutoModelForSeq2SeqLM

TRANSLATE_MODEL = "facebook/nllb-200-distilled-600M"

translator_tokenizer = AutoTokenizer.from_pretrained(TRANSLATE_MODEL)

translator_model = AutoModelForSeq2SeqLM.from_pretrained(
    TRANSLATE_MODEL
).to(device)

print("NLLB loaded successfully.")





def translate_to_bengali(text):
    inputs = translator_tokenizer(
        text,
        return_tensors="pt"
    ).to(device)

    generated_tokens = translator_model.generate(
        **inputs,
        forced_bos_token_id=translator_tokenizer.convert_tokens_to_ids("ben_Beng"),
        max_length=100
    )

    bengali_text = translator_tokenizer.batch_decode(
        generated_tokens,
        skip_special_tokens=True
    )[0]

    return bengali_text


sample = val_df.iloc[50]

image, english_caption = generate_caption(sample["image_path"])

bengali_caption = translate_to_bengali(english_caption)

plt.figure(figsize=(6,6))
plt.imshow(image)
plt.axis("off")
plt.show()

print("English Caption:")
print(english_caption)

print("\nBengali Caption:")
print(bengali_caption)





from gtts import gTTS
from IPython.display import Audio

# Convert Bengali text to speech
tts = gTTS(
    text=bengali_caption,
    lang="bn"
)

audio_path = "bengali_output.mp3"
tts.save(audio_path)

print("Audio saved:", audio_path)

# Play audio
